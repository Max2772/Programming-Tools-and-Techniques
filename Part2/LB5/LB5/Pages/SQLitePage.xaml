<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LB5.Pages.SQLitePage"
             Title="SPA"
             BackgroundColor="#F7F3F7">

    <VerticalStackLayout Spacing="12" Padding="14">

        <Border Stroke="#C9A8C9"
                StrokeThickness="1"
                Background="White"
                Padding="6"
                StrokeShape="RoundRectangle 12">
            <Picker x:Name="TypePicker"
                    Title="Выберите вид процедур..."
                    Loaded="LoadProcedureTypes"
                    SelectedIndexChanged="OnTypeSelected"
                    ItemDisplayBinding="{Binding Name}"
                    FontSize="Medium"
                    TitleColor="#AAAAAA"
                    TextColor="#3A2840" />
        </Border>

        <CollectionView x:Name="ProceduresCollectionView"
                        IsVisible="False">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#C9A8C9"
                            Background="White"
                            Padding="10"
                            StrokeShape="RoundRectangle 12">
                        <VerticalStackLayout Spacing="4">

                            <Label Text="{Binding Name}"
                                   FontSize="15"
                                   FontAttributes="Bold"
                                   TextColor="#3A2840" />

                            <Label FontSize="13" TextColor="#7A6080">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="⏱ " />
                                        <Span Text="{Binding DurationMinutes}" />
                                        <Span Text=" мин   💵 " />
                                        <Span Text="{Binding Price}" />
                                        <Span Text=" BYN" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Label x:Name="EmptyStateLabel"
               Text="Выберите вид процедур для отображения списка"
               FontSize="14"
               TextColor="#AAAAAA"
               HorizontalOptions="Center"
               HorizontalTextAlignment="Center"
               Margin="0,30,0,0" />

    </VerticalStackLayout>
</ContentPage>