<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LB6.Pages.ConverterPage"
             Title="ConverterPage"
             BackgroundColor="#12151A">

    <ContentPage.Resources>
        <ResourceDictionary>
            <Color x:Key="BgCard">#1E2229</Color>
            <Color x:Key="Accent">#D4A843</Color>
            <Color x:Key="TextPrimary">#E6EDF3</Color>
            <Color x:Key="TextSecondary">#7D8590</Color>
            <Color x:Key="Border">#2D3139</Color>
            <Color x:Key="Success">#3FB950</Color>
            <Color x:Key="Error">#F85149</Color>

            <Style x:Key="Card" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource BgCard}" />
                <Setter Property="Stroke" Value="{StaticResource Border}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="16,5" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="0,16,0,32" Spacing="0">

                <Label Text="Курсы валют"
                       TextColor="{StaticResource TextPrimary}"
                       FontSize="24"
                       FontAttributes="Bold"
                       Margin="20,8,20,2" />
                <Label x:Name="LastUpdatedLabel"
                       Text="Белорусский Национальный Банк"
                       TextColor="{StaticResource TextSecondary}"
                       FontSize="13"
                       Margin="20,0,20,12" />

                <Border Style="{StaticResource Card}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Grid.Column="0"
                               Text="Дата"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="14"
                               VerticalOptions="Center" />
                        <DatePicker x:Name="DatePicker"
                                    Grid.Column="1"
                                    Format="dd MMM yyyy"
                                    TextColor="{StaticResource Accent}"
                                    BackgroundColor="Transparent"
                                    FontSize="14"
                                    DateSelected="OnDateSelected"
                                    VerticalOptions="Center" />
                    </Grid>
                </Border>

                <ActivityIndicator x:Name="LoadingIndicator"
                                   IsRunning="False"
                                   IsVisible="False"
                                   Color="{StaticResource Accent}"
                                   HorizontalOptions="Center"
                                   Margin="0,6" />

                <CollectionView x:Name="RatesCollectionView" 
                                Margin="16,5"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="{StaticResource BgCard}"
                                    Stroke="{StaticResource Border}"
                                    StrokeThickness="1"
                                    StrokeShape="RoundRectangle 10"
                                    Padding="14,11"
                                    Margin="0,3">
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Cur_Name}"
                                               TextColor="{StaticResource TextPrimary}"
                                               FontSize="14"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding Cur_Abbreviation}"
                                               TextColor="{StaticResource TextSecondary}"
                                               FontSize="12" />
                                    </VerticalStackLayout>
                                    <Label Grid.Column="1"
                                           Text="{Binding Cur_OfficialRate, StringFormat='{0:F4} BYN'}"
                                           TextColor="{StaticResource Accent}"
                                           FontSize="15"
                                           FontAttributes="Bold"
                                           VerticalOptions="Center" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Border Style="{StaticResource Card}" Margin="16,12,16,5">
                    <VerticalStackLayout Spacing="12">

                        <Picker x:Name="CurrencyPicker"
                                Title="Выберите валюту"
                                TitleColor="{StaticResource TextSecondary}"
                                TextColor="{StaticResource TextPrimary}"
                                BackgroundColor="Transparent"
                                ItemDisplayBinding="{Binding Cur_Name}" />

                        <BoxView HeightRequest="1" BackgroundColor="{StaticResource Border}" />

                        <Border BackgroundColor="#252B34"
                                Stroke="{StaticResource Border}"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 10"
                                Padding="0">
                            <Grid ColumnDefinitions="*,Auto,*">

                                <Label Grid.Column="0"
                                       x:Name="DirectionLabel"
                                       Text="Валюта  →  BYN"
                                       TextColor="{StaticResource Accent}"
                                       FontSize="13"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       Margin="0,10" />

                                <BoxView Grid.Column="1"
                                         WidthRequest="1"
                                         BackgroundColor="{StaticResource Border}"
                                         VerticalOptions="Fill" />

                                <Button Grid.Column="2"
                                        Text="⇄ Сменить"
                                        BackgroundColor="Transparent"
                                        TextColor="{StaticResource TextSecondary}"
                                        FontSize="13"
                                        HeightRequest="40"
                                        Clicked="OnDirectionToggled" />
                            </Grid>
                        </Border>

                        <Label x:Name="EntryHintLabel"
                               Text="Введите сумму в иностранной валюте"
                               TextColor="{StaticResource TextSecondary}"
                               FontSize="12" />

                        <Entry x:Name="ValueEntry"
                               Placeholder="Введите количество"
                               PlaceholderColor="{StaticResource TextSecondary}"
                               TextColor="{StaticResource TextPrimary}"
                               BackgroundColor="Transparent"
                               Keyboard="Numeric"
                               FontSize="16" />

                    </VerticalStackLayout>
                </Border>

                <Button Text="Конвертировать"
                        BackgroundColor="{StaticResource Accent}"
                        TextColor="#12151A"
                        FontSize="15"
                        FontAttributes="Bold"
                        CornerRadius="12"
                        HeightRequest="50"
                        Margin="16,8"
                        Clicked="OnConvertClicked" />

                <Border x:Name="ResultCard"
                        Style="{StaticResource Card}"
                        IsVisible="False">
                    <Border.Stroke>
                        <SolidColorBrush Color="{StaticResource Success}" />
                    </Border.Stroke>
                    <Label x:Name="ResultLabel"
                           TextColor="{StaticResource TextPrimary}"
                           FontSize="18"
                           FontAttributes="Bold" />
                </Border>

                <Border x:Name="ErrorCard"
                        Style="{StaticResource Card}"
                        IsVisible="False">
                    <Border.Stroke>
                        <SolidColorBrush Color="{StaticResource Error}" />
                    </Border.Stroke>
                    <Label x:Name="ErrorLabel"
                           TextColor="{StaticResource Error}"
                           FontSize="14" />
                </Border>

            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>