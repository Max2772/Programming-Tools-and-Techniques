<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LB78.UI.Pages.AddOrEditSushiSetWindow"
             xmlns:models="clr-namespace:LB78.UI.ViewModels"
             x:DataType="models:AddOrEditSushiSetViewModel"
             Title="Добавить или изменить набор">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Сохранить" Command="{Binding AddOrEditSushiSetCommand}" />
    </ContentPage.ToolbarItems>

    <ContentPage.Content>
        <VerticalStackLayout>
            <Border Margin="10" Padding="5">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Название набора" />
                    <Entry Placeholder="Название" Text="{Binding Name}" />
                    <Label Text="Цена" />
                    <Entry Placeholder="Цена" Keyboard="Numeric" Text="{Binding Price}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ContentPage.Content>

</ContentPage>
